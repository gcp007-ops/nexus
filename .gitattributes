# Canonical line endings: LF everywhere.
# Prevents CRLF/LF churn on Windows checkouts (this repo is cross-platform:
# WSL + Windows + macOS contributors) and renormalizes the working tree on
# clone. See docs/plans/ for the history that motivated this.

* text=auto eol=lf

# Source
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.jsx         text eol=lf

# Config & data
*.json        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.xml         text eol=lf

# Docs & web
*.md          text eol=lf
*.txt         text eol=lf
*.html        text eol=lf
*.htm         text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.svg         text eol=lf

# Shell & misc text
*.sh          text eol=lf
*.bash        text eol=lf
*.ps1         text eol=lf
*.bat         text eol=lf
*.cmd         text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binary assets (prevent any text normalization)
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.bmp         binary
*.pdf         binary
*.mp3         binary
*.mp4         binary
*.wav         binary
*.m4a         binary
*.ogg         binary
*.webm        binary
*.zip         binary
*.gz          binary
*.tar         binary
*.wasm        binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
*.otf         binary
